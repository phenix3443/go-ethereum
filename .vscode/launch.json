  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Geth",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": ["--datadir=data", "--http", "--http.api=eth,web3,net"]
    },
    {
      "name": "dev mode",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": [
        "--dev",
        "--http",
        "--http.api=eth,web3,net",
        "--miner.etherbase=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
        "--datadir=data",
        "--password=data/password.txt"
      ]
    }
  ]
}
