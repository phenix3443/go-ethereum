{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    // sepolia
    {
      "name": "sepolia",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": [
        "--sepolia",
        "--datadir=${userHome}/Downloads/sepolia",
        "--keystore=${workspaceFolder}/data/keystore",
        "--authrpc.addr=localhost",
        "--authrpc.port=8551",
        "--authrpc.vhosts=localhost",
        "--authrpc.jwtsecret=${workspaceFolder}/data/jwtsecret",
        "--http",
        "--http.api=eth,web3,net",
        "--ws",
        "--ws.api=eth,web3,net",
        "--signer=${workspaceFolder}/data/clef/clef.ipc"
      ],
      "preLaunchTask": "Prepare Sepolia",
      "postDebugTask": "Clean Keystore"
    },
    // dev mode
    {
      "name": "dev mode",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": [
        "--dev",
        "--http",
        "--http.api=eth,web3,net,greeting",
        "--ws",
        "--ws.api=eth,web3,net,greeting",
        "--miner.etherbase=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
        "--datadir=${workspaceFolder}/data/dev",
        "--keystore=${workspaceFolder}/data/keystore",
        "--password=${workspaceFolder}/data/password.txt"
      ],
      "preLaunchTask": "Import Private Key",
      "postDebugTask": "Clean Keystore"
    },
    // private mode
    {
      "name": "private mode",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": [
        "--http",
        "--http.api=eth,web3,net",
        "--ws",
        "--ws.api=eth,web3,net",
        "--miner.etherbase=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
        "--datadir=${workspaceFolder}/data/private",
        "--keystore=${workspaceFolder}/data/keystore",
        "--password=${workspaceFolder}/data/password.txt",
        "--nodiscover",
        "--allow-insecure-unlock",
        "--unlock=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266",
        "--mine"
      ],
      "preLaunchTask": "Import Private Key",
      "postDebugTask": "Clean Keystore"
    },
    // export
    {
      "name": "export",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "cmd/geth",
      "args": [
        "export",
        "--datadir=${workspaceFolder}/data/dev",
        // "--keystore=${workspaceFolder}/data/keystore",
        // "--password=${workspaceFolder}/data/password.txt"
        "export.rlp",
        "--db.engine=leveldb"
      ]
    }
  ]
}
