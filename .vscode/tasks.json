{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "create data",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/data/keystore"
    },
    {
      "label": "create account",
      "dependsOn": ["create data"],
      "type": "shell",
      "command": "clef",
      "args": ["newaccount", "--keystore=${workspaceFolder}/data/keystore"]
    },
    {
      "label": "start clef",
      "type": "shell",
      "dependsOn": ["create data"],
      "command": "clef",
      "args": [
        "--keystore=${workspaceFolder}/data/keystore",
        "--configdir=${workspaceFolder}/data/clef",
        "--chainid=11155111"
      ]
    },
    {
      "label": "start geth",
      "type": "shell",
      "command": "geth",
      "args": [
        "--sepolia",
        "--datadir=${workspaceFolder}/data",
        "--authrpc.addr=localhost",
        "--authrpc.port=8551",
        "--authrpc.vhosts=localhost",
        "--authrpc.jwtsecret=${workspaceFolder}/data/jwtsecret",
        "--http",
        "--http.api=eth,net",
        "--signer=${workspaceFolder}/data/clef/clef.ipc"
      ]
    },
    {
      "label": "install lighthouse",
      "type": "shell",
      "command": ["brew install lighthouse"]
    },
    {
      "label": "start lighthouse",
      "dependsOn": ["install lighthouse"],
      "type": "shell",
      "command": "lighthouse",
      "args": [
        "bn",
        "--datadir=${workspaceFolder}/data",
        "--network=sepolia",
        "--execution-endpoint=http://localhost:8551",
        "--execution-jwt=${workspaceFolder}/data/jwtsecret",
        "--checkpoint-sync-url=https://sepolia.beaconstate.info",
        "--http"
      ]
    }
  ]
}
