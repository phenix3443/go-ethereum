{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "create data",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/data/sepolia"
    },
    {
      "label": "create sepolia data",
      "type": "shell",
      "command": "mkdir -p sepolia",
      "options": {
        "cwd": "${workspaceFolder}/data/"
      }
    },
    {
      "label": "create account",
      "type": "shell",
      "dependsOn": ["create data"],
      "command": "mkdir -p clef/keystore && clef newaccount --keystore=clef/keystore",
      "options": {
        "cwd": "${workspaceFolder}/data/"
      }
    },
    {
      "label": "start clef",
      "type": "shell",
      "command": "clef",
      "args": [
        "--keystore=clef/keystore",
        "--configdir=clef",
        "--chainid=11155111"
      ],
      "options": {
        "cwd": "${workspaceFolder}/data/"
      }
    },
    {
      "label": "start geth",
      "type": "shell",
      "dependsOn": ["create sepolia data"],
      "command": "geth",
      "args": [
        "--sepolia",
        "--datadir=sepolia",
        "--authrpc.addr=localhost",
        "--authrpc.port=8551",
        "--authrpc.vhosts=localhost",
        "--authrpc.jwtsecret=sepolia/jwtsecret",
        "--http",
        "--http.api=eth,net",
        "--signer=clef/clef.ipc"
      ],
      "options": {
        "cwd": "${workspaceFolder}/data/"
      }
    },
    {
      "label": "install lighthouse",
      "type": "shell",
      "command": ["brew install lighthouse"]
    },
    {
      "label": "start lighthouse",
      "dependsOn": ["install lighthouse"],
      "type": "shell",
      "command": "lighthouse",
      "args": [
        "bn",
        "--datadir=sepolia",
        "--network=sepolia",
        "--execution-endpoint=http://localhost:8551",
        "--execution-jwt=sepolia/jwtsecret",
        "--checkpoint-sync-url=https://sepolia.beaconstate.info",
        "--http"
      ],
      "options": {
        "cwd": "${workspaceFolder}/data"
      }
    }
  ]
}
