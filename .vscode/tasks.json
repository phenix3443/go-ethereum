{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "send eth",
      "type": "shell",
      "command": "cast send 0x70997970C51812dc3A010C7d01b50e0d17dc79C8 --value 1000ether ",
      "options": {
        "env": {
          "ETH_RPC_URL": "http://localhost:8545",
          "ETH_KEYSTORE": "data/keystore",
          "ETH_FROM": "0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266"
        }
      },
      "group": "test"
    },
    {
      "label": "build",
      "type": "shell",
      "command": "make all",
      "group": "build"
    },
    {
      "label": "import private key",
      "type": "shell",
      "command": "build/bin/geth account import --datadir=data --password data/password.txt data/privateKey.txt"
    },
    {
      "label": "create account",
      "type": "shell",
      "dependsOn": ["create data"],
      "command": "clef newaccount --keystore=/data/keystore"
    },
    {
      "label": "start clef",
      "type": "shell",
      "command": "clef",
      "args": [
        "--keystore=data/keystore",
        "--configdir=data/clef",
        "--chainid=11155111"
      ]
    },
    {
      "label": "start geth",
      "type": "shell",
      "command": "geth",
      "args": [
        "--sepolia",
        "--datadir=data/",
        "--authrpc.addr=localhost",
        "--authrpc.port=8551",
        "--authrpc.vhosts=localhost",
        "--authrpc.jwtsecret=data/jwtsecret",
        "--http",
        "--http.api=eth,net",
        "--signer=data/clef/clef.ipc"
      ]
    },
    {
      "label": "install lighthouse",
      "type": "shell",
      "command": ["brew install lighthouse"]
    },
    {
      "label": "start lighthouse",
      "type": "shell",
      "command": "lighthouse",
      "args": [
        "bn",
        "--datadir=data",
        "--network=sepolia",
        "--execution-endpoint=http://localhost:8551",
        "--execution-jwt=data/jwtsecret",
        "--checkpoint-sync-url=https://sepolia.beaconstate.info",
        "--http"
      ]
    }
  ]
}
