{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    // send eth
    {
      "label": "Send Eth",
      "type": "shell",
      "command": "cast",
      "args": [
        "send",
        "0x70997970C51812dc3A010C7d01b50e0d17dc79C8",
        "--value=1ether",
        "--private-key=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80",
        "--async",
        "--rpc-url=http://localhost:8545"
      ],
      "group": "test"
    },
    // build geth
    {
      "label": "Build",
      "type": "shell",
      "command": "make all",
      "group": "build"
    },
    {
      "label": "Create Keystore",
      "type": "shell",
      "command": "mkdir -p ${workspaceFolder}/data/keystore",
      "presentation": {
        "close": true
      }
    },
    // import private key
    {
      "label": "Import Private Key",
      "type": "shell",
      "dependsOn": ["Create Keystore"],
      "command": "build/bin/geth",
      "args": [
        "account",
        "import",
        "--keystore=${workspaceFolder}/data/keystore",
        "--password=${workspaceFolder}/data/password.txt",
        "${workspaceFolder}/data/privateKey.txt"
      ],
      "presentation": {
        "close": true
      }
    },
    // create account
    {
      "label": "Create Account",
      "type": "shell",
      "dependsOn": ["create data"],
      "command": "clef newaccount --keystore=/data/keystore"
    },
    // start clef
    {
      "label": "Start Clef",
      "type": "shell",
      "dependsOn": ["Import Private Key"],
      "command": "clef",
      "args": [
        "--keystore=${workspaceFolder}/data/keystore",
        "--configdir=${workspaceFolder}/data/clef",
        "--chainid=11155111"
      ],
      "presentation": {
        "panel": "dedicated",
        "close": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "noproblem"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Clef is an account management tool",
          "endsPattern": "extapi_ipc"
        }
      }
    },
    // start geth
    {
      "label": "Start Geth",
      "type": "shell",
      "command": "build/cmd/geth",
      "args": [
        "--sepolia",
        "--datadir=${workspaceFolder}/data/sepolia",
        "--keystore=${workspaceFolder}/data/keystore",
        "--authrpc.addr=localhost",
        "--authrpc.port=8551",
        "--authrpc.vhosts=localhost",
        "--authrpc.jwtsecret=${workspaceFolder}/data/jwtsecret",
        "--http",
        "--http.api=eth,net",
        "--signer=${workspaceFolder}/data/clef/clef.ipc"
      ]
    },
    // Install Lighthouse
    {
      "label": "Install Lighthouse",
      "type": "shell",
      "command": ["brew install lighthouse"]
    },
    // start consensus layer node
    {
      "label": "Start CE",
      "type": "shell",
      "command": "lighthouse",
      "args": [
        "bn",
        "--datadir=${workspaceFolder}/data/sepolia",
        "--network=sepolia",
        "--execution-endpoint=http://localhost:8551",
        "--execution-jwt=${workspaceFolder}/data/jwtsecret",
        "--checkpoint-sync-url=https://sepolia.beaconstate.info",
        "--http"
      ],
      "presentation": {
        "panel": "dedicated",
        "close": true
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "noproblem"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Lighthouse started",
          "endsPattern": "Starting beacon chain"
        }
      }
    },
    // prepare sepolia
    {
      "label": "Prepare Sepolia",
      "dependsOn": ["Start CE", "Start Clef"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false,
        "close": true
      }
    },
    // clean geth
    {
      "label": "Clean Geth",
      "type": "shell",
      "command": "git clean -f -d",
      "presentation": {
        "close": true
      }
    },
    // clean keystore
    {
      "label": "Clean Keystore",
      "type": "shell",
      "command": "rm -fr ${workspaceFolder}/data/keystore",
      "presentation": {
        "close": true
      }
    }
  ]
}
